# ============================================================
# HCIE FINAL STACK — environment template
# Copy to .env and fill in the values marked REQUIRED.
# ============================================================

# ------------------------------------------------------------
# Admin seed (used by seed-admin service / seed_admin.py)
# ------------------------------------------------------------
ADMIN_EMAIL=admin@hcie.local
ADMIN_PASSWORD=           # REQUIRED — set before running seed-admin
ADMIN_NAME=Admin

# ------------------------------------------------------------
# Auth / JWT
# ------------------------------------------------------------
SECRET_KEY=               # REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=           # REQUIRED — can be same as SECRET_KEY or a separate key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------
# Postgres — compose reads ${POSTGRES_PASSWORD} (default below = hcie_password for
# local dev). Set a real value here (or via your secrets manager) for any non-local DB.
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=hcie
POSTGRES_USER=hcie_user
POSTGRES_PASSWORD=hcie_password

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=56379

# ------------------------------------------------------------
# Kafka / Redpanda
# ------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# ------------------------------------------------------------
# Frontend / Next.js public URLs
# When using the gateway on port 80:
#   NEXT_PUBLIC_API_URL=http://localhost
#   NEXT_PUBLIC_WS_URL=ws://localhost
#   NEXT_PUBLIC_BACKEND_URL=http://localhost
# When pointing directly at the API on port 8011:
#   NEXT_PUBLIC_BACKEND_URL=http://localhost:8011
# When exposed via Tailscale (replace with your machine's Tailscale IP/hostname):
#   NEXT_PUBLIC_API_URL=http://100.x.y.z
#   NEXT_PUBLIC_BACKEND_URL=http://100.x.y.z:8011
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost
NEXT_PUBLIC_BACKEND_URL=http://localhost

# ------------------------------------------------------------
# Tailscale (optional — only needed if using Tailscale for remote access)
# Get your auth key from: https://login.tailscale.com/admin/settings/keys
# ------------------------------------------------------------
TS_AUTHKEY=               # optional — tskey-auth-... from Tailscale admin panel

# ------------------------------------------------------------
# DLQ / self-healing (only needed with --profile self-healing)
# ------------------------------------------------------------
DLQ_TOPIC=hcie-events-dlq
DLQ_MAIN_TOPIC=user-interactions
DLQ_REPLAY_TOPIC=hcie-events-replay
DLQ_COMMAND_TOPIC=hcie-replay-commands
DLQ_POISON_AFTER_ATTEMPTS=5
DLQ_ENABLE_RESEARCH_REPLAY=true

# ------------------------------------------------------------
# Observability (only needed with --profile observability/tracing)
# ------------------------------------------------------------
HCIE_ENABLE_OTLP_EXPORTER=false
