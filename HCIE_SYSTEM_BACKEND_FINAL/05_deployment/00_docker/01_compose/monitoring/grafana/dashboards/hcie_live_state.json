{
  "uid": "hcie-live-state",
  "title": "HCIE Live State",
  "tags": ["hcie", "thesis", "contribution-c"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "API request rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"hcie-api\"}[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "API container CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".*hcie-final-api.*\"}[5m])",
          "legendFormat": "cpu"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Postgres connections",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\"}",
          "legendFormat": "connections"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Redis memory",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "bytes"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Trajectory recorder commits (proxy: API writes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "description": "During autopilot or live /learn sessions, API request rate should climb. Cross-check with Dozzle trajectory-recorder logs.",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"hcie-api\",handler=~\".*attempt.*|.*recommend.*\"}[5m]))",
          "legendFormat": "learn req/s"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "title": "Container memory (all HCIE)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\".*hcie-final.*\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
