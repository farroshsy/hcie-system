              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "❌ Not significant"
                },
                "1.96": {
                  "color": "yellow",
                  "index": 1,
                  "text": "⚠️ Weak evidence"
                },
                "2.5": {
                  "color": "green",
                  "index": 2,
                  "text": "✅ Strong evidence"
                }
              },
              "type": "value"
            }
          ]
        }
