    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "(\n  sum by (mode) (hcie_mastery_delta_sum_total)\n  /\n  sum by (mode) (hcie_mastery_delta_count_total)\n)",
          "refId": "A",
          "legendFormat": "{{mode}} mean"
        },
        {
          "expr": "(\n  (\n    sum by (mode) (hcie_mastery_delta_sq_sum_total)\n    /\n    sum by (mode) (hcie_mastery_delta_count_total)\n  )\n  -\n  (\n    (\n      sum by (mode) (hcie_mastery_delta_sum_total)\n      /\n      sum by (mode) (hcie_mastery_delta_count_total)\n    ) ^ 2\n  )\n)",
          "refId": "B",
          "legendFormat": "{{mode}} variance"
        }
