      "options": {
        "displayMode": "list",
        "orientation": "horizontal"
      },
      "type": "stat",
      "title": "📈 Mean ΔM & Variance by Mode"
    },
    {
      "datasource": {
        "type": "prometheus", 
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "(\n  (\n    sum(hcie_mastery_delta_sum_total{mode=\"adaptive\"}) / sum(hcie_mastery_delta_count_total{mode=\"adaptive\"})\n  )\n  -\n  (\n    sum(hcie_mastery_delta_sum_total{mode=\"fixed_high\"}) / sum(hcie_mastery_delta_count_total{mode=\"fixed_high\"})\n  )\n)\n/\n(\n  sqrt(\n    (\n      sum(hcie_mastery_delta_sq_sum_total{mode=\"adaptive\"}) / sum(hcie_mastery_delta_count_total{mode=\"adaptive\"})\n      -\n      (\n        sum(hcie_mastery_delta_sum_total{mode=\"adaptive\"}) / sum(hcie_mastery_delta_count_total{mode=\"adaptive\"})\n      ) ^ 2\n    ) / sum(hcie_mastery_delta_count_total{mode=\"adaptive\"})\n    +\n    (\n      sum(hcie_mastery_delta_sq_sum_total{mode=\"fixed_high\"}) / sum(hcie_mastery_delta_count_total{mode=\"fixed_high\"})\n      -\n      (\n        sum(hcie_mastery_delta_sum_total{mode=\"fixed_high\"}) / sum(hcie_mastery_delta_count_total{mode=\"fixed_high\"})\n      ) ^ 2\n    ) / sum(hcie_mastery_delta_count_total{mode=\"fixed_high\"})\n  )\n)",
          "refId": "A",
          "legendFormat": "t-score (adaptive vs fixed_high)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow", 
                "value": 1.96
              },
              {
                "color": "green",
                "value": 2.5
              }
            ]
          },
          "mappings": [
