{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning Event Schema",
  "description": "Schema for user learning interaction events",
  "type": "object",
  "version": 1,
  "required": [
    "event_id",
    "user_id", 
    "event_type",
    "reward",
    "task_id",
    "concept",
    "timestamp"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Event schema version",
      "enum": [1],
      "default": 1
    },
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event"
    },
    "user_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the user"
    },
    "event_type": {
      "type": "string",
      "enum": ["task_submitted", "task_completed", "concept_mastered"],
      "description": "Type of learning event"
    },
    "reward": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Learning reward value (0.0 to 1.0)"
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier for the task"
    },
    "concept": {
      "type": "string",
      "minLength": 1,
      "description": "Learning concept associated with the task"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the event occurred"
    },
    "metadata": {
      "type": "object",
      "description": "Optional additional metadata",
      "properties": {
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "attempts": {
          "type": "integer",
          "minimum": 1
        },
        "time_spent": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
