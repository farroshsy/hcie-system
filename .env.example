# HCIE — environment template. Copy to `.env` (or run `make init`) and fill the REQUIRED values.
# Most variables have sensible defaults in HCIE_SYSTEM_BACKEND_FINAL/04_config/00_schemas/settings.py;
# only the ones marked REQUIRED must be set. Never commit a real .env.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-please          # REQUIRED — bootstrap admin account (compose refuses to start without it)
JWT_SECRET_KEY=change-me-32+chars        # REQUIRED — token signing secret

# ── Datastores (defaults match the compose network; override only if external) ──
POSTGRES_HOST=hcie-final-postgres
POSTGRES_PORT=5432
POSTGRES_DB=hcie
POSTGRES_USER=hcie_user
POSTGRES_PASSWORD=hcie_password
DATABASE_URL=postgresql://hcie_user:hcie_password@hcie-final-postgres:5432/hcie
REDIS_HOST=hcie-final-redis
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=hcie-final-kafka:9092

# ── Runtime ─────────────────────────────────────────────────────────────────
ENVIRONMENT=docker
DOCKER_ENV=true
ENABLE_BACKGROUND_WORKERS=true
# Reproducibility: deterministic mode makes the in-process brain bit-identical (seed + PYTHONHASHSEED).
ENABLE_DETERMINISTIC_MODE=false
DETERMINISTIC_SEED=42
# CORS for the frontend (adjust to your host)
CORS_ORIGINS=http://localhost:3001

# Frontend env templates live in HCIE_SYSTEM_FRONTENDV3/.env.example.
