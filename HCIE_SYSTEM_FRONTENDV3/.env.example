# API Configuration
# FINAL backend (hcie-final-api) runs on host port 8011.
# The V2 stack on :8001 is legacy and should not be used for thesis runs.
NEXT_PUBLIC_API_URL=http://localhost:8011
NEXT_PUBLIC_BACKEND_URL=http://localhost:8011
NEXT_PUBLIC_WS_URL=ws://localhost:8011

# Application Configuration
NEXT_PUBLIC_APP_NAME=HCIE
NEXT_PUBLIC_APP_VERSION=3.0.0
NEXT_PUBLIC_APP_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_MATHLIVE=true
NEXT_PUBLIC_ENABLE_DAG_VISUALIZATION=true
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=true
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_FEATURES=true
NEXT_PUBLIC_ENABLE_DEBUG_MODE=true

# Authentication (keep mock until backend auth is ready)
NEXT_PUBLIC_USE_MOCK_AUTH=false

# Analytics (optional - add your tracking IDs)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_SENTRY_DSN=
